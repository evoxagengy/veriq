generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MASTER
  ADMIN
  MANAGER
  SUPERVISOR
  OPERATOR
  TECHNICIAN
  INSPECTOR
}

enum EquipmentStatus {
  OPERATING
  MAINTENANCE
  INACTIVE
  CRITICAL
  ATTENTION
}

enum ChecklistStatus {
  ACTIVE
  DRAFT
  REVIEW
  ARCHIVED
}

enum InspectionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
  SCHEDULED
}

enum Criticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NonConformityStatus {
  OPEN
  IN_TREATMENT
  RESOLVED
  CANCELLED
}

model Tenant {
  id              String              @id @default(cuid())
  name            String
  slug            String              @unique
  active          Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  users           User[]
  equipments      Equipment[]
  checklists      ChecklistTemplate[]
  inspections     Inspection[]
  nonConformities NonConformity[]
  auditLogs       AuditLog[]
  settings        TenantSettings?
  checklistBlocks ChecklistBlock[]
}

model User {
  id               String        @id @default(cuid())
  tenantId         String
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  email            String        @unique
  role             Role          @default(OPERATOR)
  passwordHash     String
  avatarUrl        String?
  department       String?
  position         String?
  phone            String?
  active           Boolean       @default(true)
  failedLoginCount Int           @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  sessions         Session[]
  auditLogs        AuditLog[]
  ownedEquipment   Equipment[]   @relation("EquipmentResponsible")
  ownedChecklists  ChecklistTemplate[] @relation("ChecklistResponsible")
  assignedInspections Inspection[] @relation("InspectionAssignee")
  reportedNonConformities NonConformity[] @relation("NonConformityReporter")
  assignedNonConformities NonConformity[] @relation("NonConformityAssignee")

  @@index([tenantId])
  @@index([role])
}

model TenantSettings {
  id                       String   @id @default(cuid())
  tenantId                 String   @unique
  tenant                   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyName              String
  checklistApprovalEnabled Boolean  @default(true)
  inspectionGraceMinutes   Int      @default(30)
  evidenceRequired         Boolean  @default(false)
  notifyOverdue            Boolean  @default(true)
  notifyCriticalFailures   Boolean  @default(true)
  dataRetentionDays        Int      @default(1825)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Session {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash     String    @unique
  ipHash        String?
  userAgentHash String?
  expiresAt     DateTime
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model LoginAttempt {
  id          String    @id @default(cuid())
  identifier  String
  ipHash      String
  attempts    Int       @default(0)
  lockedUntil DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([identifier, ipHash])
  @@index([lockedUntil])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String?
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ipHash     String?
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
}

model Equipment {
  id                   String          @id @default(cuid())
  tenantId             String
  tenant               Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tag                  String
  name                 String
  category             String
  area                 String
  model                String?
  manufacturer         String?
  serialNumber         String?
  location             String?
  description          String?
  status               EquipmentStatus @default(OPERATING)
  criticality          Criticality     @default(MEDIUM)
  active               Boolean         @default(true)
  monitorOnDashboard   Boolean         @default(true)
  allowChecklists      Boolean         @default(true)
  requiresStopApproval Boolean         @default(false)
  lastChecklistAt      DateTime?
  nextInspectionAt     DateTime?
  responsibleId        String?
  responsible          User?           @relation("EquipmentResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  inspections          Inspection[]
  nonConformities      NonConformity[]
  checklists           ChecklistTemplate[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@unique([tenantId, tag])
  @@index([tenantId, status])
  @@index([tenantId, category])
}

model ChecklistTemplate {
  id                String            @id @default(cuid())
  tenantId          String
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code              String
  name              String
  category          String
  area              String
  periodicity       String
  description       String?
  status            ChecklistStatus   @default(ACTIVE)
  blockId           String?
  block             ChecklistBlock?   @relation(fields: [blockId], references: [id], onDelete: SetNull)
  equipmentId       String?
  equipment         Equipment?         @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  estimatedMinutes  Int               @default(30)
  requiresApproval  Boolean           @default(false)
  allowsPhotos      Boolean           @default(true)
  requiresSignature Boolean           @default(true)
  mobileEnabled     Boolean           @default(true)
  responsibleId     String?
  responsible       User?             @relation("ChecklistResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  items             ChecklistItem[]
  inspections       Inspection[]
  nonConformities   NonConformity[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, category])
  @@index([tenantId, blockId])
  @@index([tenantId, equipmentId])
}

model ChecklistBlock {
  id          String              @id @default(cuid())
  tenantId    String
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  active      Boolean             @default(true)
  checklists  ChecklistTemplate[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, active])
}

model ChecklistItem {
  id                  String            @id @default(cuid())
  templateId          String
  template            ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  position            Int
  description         String
  responseType        String
  criticality         Criticality       @default(MEDIUM)
  required            Boolean           @default(true)
  active              Boolean           @default(true)
  nonConformityAction String             @default("OPEN_OCCURRENCE")
  answers             InspectionAnswer[]

  @@unique([templateId, position])
  @@index([templateId, active])
}

model Inspection {
  id          String            @id @default(cuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templateId  String
  template    ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  equipmentId String?
  equipment   Equipment?        @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  assignedToId String?
  assignedTo  User?             @relation("InspectionAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  status      InspectionStatus  @default(PENDING)
  dueAt       DateTime
  startedAt   DateTime?
  completedAt DateTime?
  score       Decimal?          @db.Decimal(5, 2)
  notes       String?
  answers     InspectionAnswer[]
  nonConformities NonConformity[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, dueAt])
  @@index([assignedToId, status])
}

model InspectionAnswer {
  id           String        @id @default(cuid())
  inspectionId String
  inspection   Inspection    @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  itemId       String
  item         ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  value        String
  compliant    Boolean       @default(true)
  note         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([inspectionId, itemId])
  @@index([inspectionId])
}

model NonConformity {
  id           String              @id @default(cuid())
  tenantId     String
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code         String
  title        String
  description  String
  severity     Criticality         @default(MEDIUM)
  status       NonConformityStatus @default(OPEN)
  rootCause    String?
  correctiveAction String?
  dueAt        DateTime?
  resolvedAt   DateTime?
  reportedById String?
  reportedBy   User?               @relation("NonConformityReporter", fields: [reportedById], references: [id], onDelete: SetNull)
  assignedToId String?
  assignedTo   User?               @relation("NonConformityAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  inspectionId String?
  inspection   Inspection?         @relation(fields: [inspectionId], references: [id], onDelete: SetNull)
  equipmentId  String?
  equipment    Equipment?          @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  checklistId  String?
  checklist    ChecklistTemplate?  @relation(fields: [checklistId], references: [id], onDelete: SetNull)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, severity])
  @@index([assignedToId, status])
}
